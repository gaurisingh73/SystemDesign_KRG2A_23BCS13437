    <mxGraphModel dx="1261" dy="944" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="0IM3H2zbaznv-EizjkQZ-1" parent="1" style="rounded=0;whiteSpace=wrap;html=1;dashed=1;" value="Design an Instagram like system with the following requirements :&amp;nbsp;&lt;div&gt;- User login service&lt;/div&gt;&lt;div&gt;- Content service&lt;/div&gt;&lt;div&gt;- Feed Service&lt;/div&gt;&lt;div&gt;- Follower Service&amp;nbsp;&lt;/div&gt;&lt;div&gt;- User Engagement Service&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Implement a mechanism to restrict the user for posting a non policy compliant post.&lt;/div&gt;&lt;div&gt;Optimize the dynamic feed generator for the users.&lt;/div&gt;&lt;div&gt;Highlight the use of backfill services.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="180" width="530" x="50" y="60" as="geometry" />
        </mxCell>
        <mxCell id="0IM3H2zbaznv-EizjkQZ-2" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;" value="1. Functional Requirements :&amp;nbsp;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;- User should be able to signup/login.&lt;/div&gt;&lt;div&gt;- User should be able to post content.&amp;nbsp;&lt;/div&gt;&lt;div&gt;- User should be able to check others&#39; feeds.&lt;/div&gt;&lt;div&gt;- User should be able to send and receive follow requests.&lt;/div&gt;&lt;div&gt;- Content uploaded should fall under policy compliance.&lt;/div&gt;&lt;div&gt;- Search for content through tags&amp;nbsp;&lt;/div&gt;&lt;div&gt;- Search for users&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;2. Non- Functional Requirements :&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;- Availability : Should be 99.99% available. (Read heavy)&lt;/div&gt;&lt;div&gt;- Consistency : System should be consistent. Posts should not be corrupted.&lt;/div&gt;&lt;div&gt;- Scalability : Should be able to manage 100 M DAU with each user posting 10 posts a day.&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&amp;nbsp;3. API calls :&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;- get call for fetching the feed&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;- post call for writing to the feed&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;- get call for fetching others&#39; profile&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;- post call for sending follow request&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;- get call for receiving follow request&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;4. Core entities :&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;- User&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;- Posts&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;-&amp;nbsp;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="440" width="600" x="50" y="270" as="geometry" />
        </mxCell>
